rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // ==========================================
    // SECURITY HELPERS FOR STORAGE
    // ==========================================
    
    // Check if the user is logged in
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Check if the user is the registered Owner or Admin of the company in Firestore
    function isCompanyOwnerOrAdmin(companyId) {
      let company = firestore.get(/databases/(default)/documents/companies/$(companyId));
      return company != null && (
        company.data.owner_uid == request.auth.uid || 
        company.data.admin_email == request.auth.token.email
      );
    }
    
    // Check if the user is listed under the company staff users in Firestore
    function isCompanyStaff(companyId) {
      return firestore.exists(/databases/(default)/documents/companies/$(companyId)/users/$(request.auth.uid));
    }
    
    // Verify if the user has active membership inside the company tenant
    function belongsToCompany(companyId) {
      return isAuthenticated() && (isCompanyOwnerOrAdmin(companyId) || isCompanyStaff(companyId));
    }

    // ==========================================
    // STORAGE LOCATION RULES
    // ==========================================

    // Company uploads (Logos, signatures, employee face images, documents)
    match /companies/{companyId}/uploads/{fileName} {
      allow read, write: if belongsToCompany(companyId);
    }

    // Fallback individual user folders
    match /users/{userId}/{fileName} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }
  }
}
